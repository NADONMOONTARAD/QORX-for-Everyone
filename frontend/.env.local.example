# ไฟล์ตัวอย่างนี้ commit ได้ แต่ไฟล์ frontend/.env.local จริงไม่ควรถูก commit
#
# Local Database Connection (PostgreSQL)
# ใช้สำหรับให้หน้าเว็บ local เชื่อมต่อกับฐานข้อมูล dev ของคุณ
# จะเป็น Postgres ในเครื่องหรือ Supabase ก็ได้ แต่ค่าตัวนี้คือ "local runtime" ของ Next เสมอ
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/postgres"

# Deployment / serverless database connection
# บน Vercel + Supabase ให้ใส่ "pooled Transaction mode" URL ลงตัวแปรนี้
# ค่านี้มีผลเฉพาะตอนรันบน Vercel
DATABASE_URL_POOLED="postgresql://USER:PASSWORD@YOUR-POOLER-HOST:6543/postgres"

# จำกัดจำนวน client ต่อ serverless instance
PG_POOL_MAX=1

# ─── Supabase Authentication (client-side) ───
# คัดลอกค่าจาก Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# ─── Admin Access Control ───
# Server-side (middleware): ใช้ ADMIN_EMAILS
# Client-side (components): ใช้ NEXT_PUBLIC_ADMIN_EMAILS
# คั่นหลายอีเมลด้วยจุลภาค เช่น admin@mail.com,boss@mail.com
ADMIN_EMAILS=admin@example.edu
NEXT_PUBLIC_ADMIN_EMAILS=admin@example.edu
