# ไฟล์ตัวอย่างนี้ commit ได้ แต่ไฟล์ .env จริงไม่ควรถูก commit
#
# -----------------------------
# AI Model & Retry Configuration
# -----------------------------
# ชื่อรุ่น AI ของ Gemini ที่จะใช้สรุปงบการเงิน (เช่น gemini-3-flash-preview, gemini-1.5-pro)
GEMINI_SUMMARY_MODEL=gemini-3-flash-preview

# กำหนดว่าจะให้ทวนซ้ำกี่ครั้ง ถ้าเกิด AI หรือเซิร์ฟเวอร์ข้อมูลล่มกลางทาง (1 = ทวนซ้ำ 1 รอบ)
UNIFIED_MAX_RETRIES=1

# หน่วงเวลากี่วินาทีก่อนจะเริ่มรันแก้ตัวในรอบที่พลาด (60 = รอ 1 นาทีก่อนลองใหม่)
UNIFIED_RETRY_DELAY_SECONDS=60
# TEST_TICKER=NVDA, BRK-B
TEST_TICKER=NVDA

# บังคับรันวิเคราะห์หุ้นใหม่เสมอ (1 = บังคับให้เริ่มใหม่แต่ต้น, 0 = ไม่บังคับ)
# ปกติถ้าระบบเคยวิเคราะห์หุ้นนี้ผ่านไปแล้วในไม่กี่วัน มันจะข้ามการทำซ้ำ
# แต่ถ้าเราแก้โค้ด AI แล้วอยากลองรันหุ้นตัวเดิมอีกรอบ ให้เซ็ตเป็น 1 ชั่วคราว
FORCE_RERUN="0"

# Set USE_DEPLOY_DB to "on" when your local Python runner should write to Supabase deploy DB
# Set it to "off" to write to your local/dev database
USE_DEPLOY_DB="off"

# -----------------------------
# API Keys (ระบบรองรับกี่ตัวก็ได้!)
# -----------------------------
# คุณสามารถใส่กุญแจเรียงกันไปได้เรื่อยๆ (GEMINI_API_KEY_1 จนถึง GEMINI_API_KEY_51 หรือ 100 ก็ได้)
# โค้ดถูกเขียนมาให้อ่านกุญแจทั้งหมดที่มีคำว่า GEMINI_API_KEY_ หรือ FINNHUB_API_KEY_ นำหน้า
# จากนั้นมันจะสุ่มสลับ (Rotation) หรือเปลี่ยนไปใช้อันถัดไปถนอมโควต้าอัตโนมัติ

# Gemini API Keys (เปลี่ยน your_gemini_api_key... เป็นคีย์ของจริง)
GEMINI_API_KEY_1="your_gemini_api_key_1"
GEMINI_API_KEY_2="your_gemini_api_key_2"
# GEMINI_API_KEY_3...

# Finnhub API Keys (สามารถใส่เรียงกี่อันก็ได้ ระบบจะสลับใช้ให้เอง)
FINNHUB_API_KEY_1="your_finnhub_api_key_1"
FINNHUB_API_KEY_2="your_finnhub_api_key_2"
# FINNHUB_API_KEY_3...

# SEC EDGAR API User-Agent (ควรเปลี่ยนอีเมล์เป็นของตัวเอง ป้องกันโดนแบน)
SEC_USER_AGENT="stock-analysis-app/1.0 (your_email@example.com)"

# Database Configuration
# Local/dev database used by the Python runner when USE_DEPLOY_DB="off"
# DBeaver เป็นแค่ client ที่ใช้เปิดดู DB นี้
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/postgres"

# Deploy database used by the Python runner when USE_DEPLOY_DB="on"
DATABASE_URL_DEPLOY="postgresql://postgres:YOUR_PASSWORD@db.xxxxxxxxxxxxxxx.supabase.co:5432/postgres"

# Frontend / Vercel pooled connection
# สำหรับ Next.js บน Vercel ให้ใช้ Supabase "pooled / Transaction mode" URL
DATABASE_URL_POOLED="postgresql://USER:PASSWORD@YOUR-POOLER-HOST:6543/postgres"

# จำกัดจำนวน client ต่อ serverless instance
PG_POOL_MAX=1

# FRED API Configuration (ข้อมูลเศรษฐกิจมหภาค)
FRED_API_KEY="your_fred_api_key_here"

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# Admin Access Control
ADMIN_EMAILS=admin@example.edu
